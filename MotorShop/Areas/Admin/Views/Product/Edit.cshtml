@model MotorShop.Models.Product
@{
    ViewData["Title"] = "Cập nhật sản phẩm";
}

<div class="max-w-7xl mx-auto">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">@Model.Name</h1>
                <a asp-action="Index" class="text-slate-500 hover:text-blue-600 flex items-center gap-1 text-sm font-medium transition-colors">
                    <i class="fa-solid fa-arrow-left"></i> Quay lại
                </a>
            </div>
            <div class="flex items-center gap-3">
                <a asp-action="Details" asp-route-id="@Model.Id" class="px-4 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-300 rounded-lg hover:bg-slate-50 transition-colors">Xem chi tiết</a>
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">Lưu thay đổi</button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <div class="lg:col-span-2 space-y-6">
                <partial name="_ProductForm" model="Model" />
            </div>

            <div class="lg:col-span-1 space-y-6">
                <div class="bg-white p-5 rounded-lg shadow ring-1 ring-black/5">
                    <h3 class="text-lg font-medium text-gray-800 mb-4">Phân loại</h3>
                    <div class="space-y-4">
                        <div>
                            <label asp-for="CategoryId" class="block text-sm font-medium text-gray-700">Danh mục</label>
                            <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                        <div>
                            <label asp-for="BrandId" class="block text-sm font-medium text-gray-700">Thương hiệu</label>
                            <select asp-for="BrandId" asp-items="ViewBag.BrandId" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm">
                                <option value="">-- Chọn thương hiệu --</option>
                            </select>
                        </div>
                        <div>
                            <label asp-for="Year" class="block text-sm font-medium text-gray-700">Năm sản xuất</label>
                            <input asp-for="Year" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" />
                            <span asp-validation-for="Year" class="text-red-500 text-xs"></span>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-5 rounded-lg shadow ring-1 ring-black/5">
                    <h3 class="text-lg font-medium text-gray-800 mb-4">Trạng thái</h3>
                    <div class="flex items-center gap-2">
                        <input asp-for="IsActive" class="h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" />
                        <label asp-for="IsActive" class="text-sm font-medium text-gray-900">Cho phép kinh doanh</label>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-6 sm:p-8 mt-6">
        <h2 class="text-xl font-semibold text-slate-800 mb-6 border-b pb-3">Quản lý hình ảnh</h2>

        <form asp-action="AddImage" method="post" enctype="multipart/form-data" class="grid grid-cols-1 sm:grid-cols-3 gap-4 p-4 border rounded-lg bg-gray-50 mb-6">
            <input type="hidden" name="ProductId" value="@Model.Id" />

            <div class="sm:col-span-2">
                <label for="file" class="block text-sm font-medium text-gray-700">Chọn file ảnh *</label>
                <input type="file" name="file" accept="image/*" required class="mt-1 block w-full text-sm text-slate-500
                    file:mr-4 file:py-2 file:px-4
                    file:rounded-full file:border-0
                    file:text-sm file:font-semibold
                    file:bg-blue-50 file:text-blue-700
                    hover:file:bg-blue-100" />
            </div>

            <div>
                <label for="Caption" class="block text-sm font-medium text-gray-700">Chú thích</label>
                <input type="text" name="Caption" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" placeholder="Ảnh 1..." />
            </div>

            <button type="submit" class="sm:col-span-3 px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 transition-colors shadow-sm">
                <i class="fa-solid fa-upload mr-1"></i> Tải ảnh lên
            </button>
        </form>

        <h3 class="text-md font-medium text-slate-700 mb-3">Các ảnh hiện tại</h3>
        @if (!Model.Images.Any())
        {
            <p class="text-sm text-gray-500">Chưa có ảnh nào cho sản phẩm này.</p>
        }
        else
        {
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                @foreach (var image in Model.Images.OrderBy(i => i.SortOrder))
                {
                    <div class="border rounded-lg overflow-hidden shadow-sm bg-white">
                        <img src="@image.ImageUrl" alt="@image.Caption" class="w-full h-32 object-cover" />
                        <div class="p-2">
                            <p class="text-xs text-gray-600 truncate" title="@image.Caption">@(image.Caption ?? "...")</p>
                            <form asp-action="DeleteImage" method="post" class="mt-2">
                                <input type="hidden" name="id" value="@image.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="w-full text-left text-xs text-red-600 hover:text-red-800 font-medium">
                                    <i class="fa-solid fa-trash-can mr-1"></i> Xoá
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}