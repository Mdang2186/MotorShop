@model Product

<div class="space-y-6">

    <div class="bg-white p-5 rounded-lg shadow ring-1 ring-black/5">
        <h3 class="text-lg font-medium text-gray-800 mb-4">Thông tin chung</h3>
        <div class="space-y-4">
            <div>
                <label asp-for="Name" class="block text-sm font-medium text-gray-700">Tên sản phẩm *</label>
                <input asp-for="Name" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" />
                <span asp-validation-for="Name" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="Description" class="block text-sm font-medium text-gray-700">Mô tả</label>
                <textarea asp-for="Description" rows="10" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm"></textarea>
                <span asp-validation-for="Description" class="text-red-500 text-xs"></span>
            </div>
        </div>
    </div>

    <div class="bg-white p-5 rounded-lg shadow ring-1 ring-black/5">
        <h3 class="text-lg font-medium text-gray-800 mb-4">Giá & Tồn kho</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
                <label asp-for="Price" class="block text-sm font-medium text-gray-700">Giá bán *</label>
                <input asp-for="Price" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" />
                <span asp-validation-for="Price" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="SKU" class="block text-sm font-medium text-gray-700">Mã SKU</label>
                <input asp-for="SKU" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm font-mono" />
                <span asp-validation-for="SKU" class="text-red-500 text-xs"></span>
            </div>
            <div>
                <label asp-for="StockQuantity" class="block text-sm font-medium text-gray-700">Tồn kho</label>
                <input asp-for="StockQuantity" type="number" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm" />
            </div>
        </div>
    </div>
</div>