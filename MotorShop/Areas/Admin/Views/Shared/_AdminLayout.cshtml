<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin MotorShop</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        /* CSS cơ bản cho sidebar và layout admin */
        body {
            background-color: #f9fafb; /* gray-50 */
        }

        .admin-sidebar {
            width: 260px;
            transition: transform 0.3s ease-in-out;
        }

        .admin-content {
            margin-left: 260px;
            transition: margin-left 0.3s ease-in-out;
        }
        /* Style cho link sidebar */
        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem; /* py-3 px-6 */
            font-size: 0.875rem; /* text-sm */
            font-weight: 500; /* font-medium */
            color: #4b5563; /* text-gray-600 */
            border-left: 4px solid transparent;
            transition: all 0.2s ease-in-out;
        }

            .sidebar-link:hover {
                background-color: #f3f4f6; /* hover:bg-gray-100 */
                color: #2563eb; /* hover:text-blue-600 */
                border-left-color: #dbeafe; /* hover:border-blue-100 */
            }
            /* Style cho link active */
            .sidebar-link.active {
                background-color: #eef2ff; /* bg-indigo-50 */
                color: #4338ca; /* text-indigo-700 */
                border-left-color: #4f46e5; /* border-indigo-600 */
                font-weight: 600; /* font-semibold */
            }
            /* Style cho icon sidebar */
            .sidebar-link i.fa-fw {
                width: 1.25rem; /* w-5 */
                text-align: center;
                margin-right: 0.75rem; /* mr-3 */
                color: #9ca3af; /* text-gray-400 */
                transition: color 0.2s ease-in-out;
            }

            .sidebar-link:hover i.fa-fw {
                color: #2563eb; /* hover:text-blue-600 */
            }

            .sidebar-link.active i.fa-fw {
                color: #4f46e5; /* text-indigo-600 */
            }

        /* Responsive Sidebar Toggle */
        #sidebar-toggle:checked ~ .admin-sidebar {
            transform: translateX(-100%);
        }

        #sidebar-toggle:checked ~ .admin-content {
            margin-left: 0;
        }
        @@media (min-width: 1024px) { /* lg breakpoint */
            #sidebar-toggle:checked ~ .admin-sidebar

        {
            transform: translateX(0);
        }

        #sidebar-toggle:checked ~ .admin-content {
            margin-left: 260px;
        }

        .sidebar-toggle-label {
            display: none;
        }
        /* Hide toggle button on large screens */
        }

        /* Top Navigation Bar */
        .top-nav {
            box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
        }
    </style>
</head>
<body class="flex min-h-screen">

    <input type="checkbox" id="sidebar-toggle" class="hidden" />

    <aside class="admin-sidebar fixed top-0 left-0 h-full bg-white border-r border-gray-200 pt-5 flex flex-col z-40 lg:translate-x-0 transform -translate-x-full">
        <div class="px-6 mb-6">
            <a asp-controller="Home" asp-action="Index" asp-area="" class="flex items-center space-x-3 group">
                <div class="w-10 h-10 bg-blue-600 rounded-lg flex items-center justify-center shadow-md group-hover:bg-blue-700 transition-colors">
                    <i class="fas fa-motorcycle text-white text-xl"></i>
                </div>
                <div>
                    <h1 class="text-lg font-bold text-blue-600 group-hover:text-blue-700 transition-colors">MotorShop</h1>
                    <p class="text-xs text-gray-500 font-medium tracking-wide">Admin Panel</p>
                </div>
            </a>
        </div>

        <nav class="flex-grow space-y-1 overflow-y-auto">
            @{
                // Helper để xác định link active
                string IsActive(string controller, string action = "Index", string area = "Admin")
                {
                    return ViewContext.RouteData.Values["controller"]?.ToString() == controller &&
                    ViewContext.RouteData.Values["action"]?.ToString() == action &&
                    ViewContext.RouteData.Values["area"]?.ToString() == area
                    ? "active" : "";
                }
            }
            <a asp-action="Index" asp-controller="Dashboard" asp-area="Admin" class="sidebar-link @IsActive("Dashboard")">
                <i class="fas fa-tachometer-alt fa-fw"></i>Tổng quan
            </a>
            <a asp-action="Index" asp-controller="Product" asp-area="Admin" class="sidebar-link @IsActive("Product")">
                <i class="fas fa-box-open fa-fw"></i>Sản phẩm
            </a>
            <a asp-action="Index" asp-controller="Order" asp-area="Admin" class="sidebar-link @IsActive("Order")">
                <i class="fas fa-receipt fa-fw"></i>Đơn hàng
            </a>
            @* <a asp-action="Index" asp-controller="User" asp-area="Admin" class="sidebar-link @IsActive("User")">
                 <i class="fas fa-users fa-fw"></i>Người dùng
            </a> *@
            <a asp-action="Index" asp-controller="Category" asp-area="Admin" class="sidebar-link @IsActive("Category")">
                @* Thêm Controller này nếu có *@
                <i class="fas fa-tags fa-fw"></i>Loại xe
            </a>
            <a asp-action="Index" asp-controller="Brand" asp-area="Admin" class="sidebar-link @IsActive("Brand")">
                @* Thêm Controller này nếu có *@
                <i class="fas fa-copyright fa-fw"></i>Thương hiệu
            </a>
            @* Thêm các mục quản lý khác ở đây *@
        </nav>

        <div class="p-4 border-t border-gray-200 mt-auto">
            <form asp-controller="Account" asp-action="Logout" asp-area="" method="post" class="w-full">
                <button type="submit" class="sidebar-link text-red-600 hover:bg-red-50 hover:text-red-700 hover:border-red-100 w-full">
                    <i class="fas fa-sign-out-alt fa-fw text-red-600"></i>Đăng xuất
                </button>
            </form>
        </div>
    </aside>

    <div class="admin-content flex-grow flex flex-col">
        <header class="top-nav bg-white h-16 flex items-center px-6 justify-between flex-shrink-0 z-30 border-b border-gray-200">
            <label for="sidebar-toggle" class="cursor-pointer sidebar-toggle-label">
                <i class="fas fa-bars text-xl text-gray-600"></i>
            </label>
            <h2 class="text-xl font-semibold text-gray-700 hidden sm:block">@ViewData["Title"]</h2>
            <div class="flex items-center">
                @* Có thể dùng lại _LoginPartial nếu bạn tùy chỉnh nó cho Admin *@
                <span class="text-sm font-medium text-gray-600">Chào, Admin!</span> @* Lấy tên admin thật *@
            </div>
        </header>

        <main class="flex-grow p-6 lg:p-8">
            @RenderBody()
        </main>

        <footer class="bg-white text-center py-4 text-sm text-gray-500 border-t border-gray-200 mt-auto">
            &copy; @DateTime.Now.Year - MotorShop Admin Panel
        </footer>
    </div>

    @* <script src="~/lib/jquery/dist/jquery.min.js"></script> *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>