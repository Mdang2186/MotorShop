@model MotorShop.Models.ApplicationUser
@{
    ViewData["Title"] = "Xoá người dùng";
}

<div class="max-w-2xl mx-auto mt-10">
    <div class="bg-white shadow-lg rounded-lg border border-red-100 overflow-hidden">
        <div class="p-6 sm:flex sm:items-start bg-red-50 border-b border-red-100">
            <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10">
                <i class="fa-solid fa-triangle-exclamation text-red-600 text-lg"></i>
            </div>
            <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                <h3 class="text-lg leading-6 font-medium text-red-800" id="modal-title">Xác nhận xoá người dùng</h3>
                <div class="mt-2">
                    <p class="text-sm text-red-700">
                        Bạn có chắc chắn muốn xoá người dùng <strong class.="font-bold">@Model.UserName</strong>?
                        Hành động này không thể hoàn tác.
                    </p>
                </div>
            </div>
        </div>

        <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-end space-x-3">
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <a asp-action="Index" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                    Hủy bỏ
                </a>
                <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 transition-colors ml-3">
                    <i class="fa-solid fa-trash-can mr-2"></i> Xác nhận xoá
                </button>
            </form>
        </div>
    </div>
</div>