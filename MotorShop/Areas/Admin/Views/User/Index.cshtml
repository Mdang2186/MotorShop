@model IEnumerable<MotorShop.Areas.Admin.Controllers.UserController.UserListItemVM>
@{
    ViewData["Title"] = "Người dùng";

    var q = (string?)ViewBag.Q ?? string.Empty;
    var role = (string?)ViewBag.Role ?? "";
    int page = (int)(ViewBag.Page ?? 1);
    int pageSize = (int)(ViewBag.PageSize ?? 15);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<h1 class="text-2xl font-semibold mb-4 text-slate-900">Người dùng & Phân quyền</h1>

<div class="bg-white rounded-xl shadow ring-1 ring-black/5">

    <form method="get" class="p-4 border-b border-gray-100">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-3">
                <input name="q" value="@q" class="border rounded-md px-3 py-2 text-sm w-40" placeholder="Tìm tên, email..." />

                <select name="role" asp-items="ViewBag.Roles" class="border rounded-md px-3 py-2 text-sm">
                    <option value="">-- Lọc theo vai trò --</option>
                </select>

                <select name="pageSize" class="border rounded-md px-3 py-2 text-sm">
                    <option value="15" selected="@(pageSize == 15)">Hiển thị: 15</option>
                    <option value="25" selected="@(pageSize == 25)">Hiển thị: 25</option>
                    <option value="50" selected="@(pageSize == 50)">Hiển thị: 50</option>
                </select>

                <button class="px-3 py-2 rounded-md bg-slate-100 text-slate-700 text-sm font-medium hover:bg-slate-200">Lọc</button>
            </div>

            <div>
                <a asp-action="Create" class="px-3 py-2 rounded-md bg-blue-600 text-white text-sm font-medium shadow-sm hover:bg-blue-700">
                    <i class="fa fa-plus mr-1"></i> Tạo người dùng
                </a>
            </div>
        </div>
    </form>

    <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
                    <th class="px-6 py-3 w-1/3">Tài khoản</th>
                    <th class="px-6 py-3">Email</th>
                    <th class="px-6 py-3">Vai trò</th>
                    <th class="px-6 py-3">Ngày tạo</th>
                    <th class="px-6 py-3">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var u in Model)
                {
                    <tr class="clickable-row" data-href="@Url.Action("Details", "User", new { id = u.Id })">
                        <td class="px-6 py-4">
                            <div class="font-semibold text-slate-900">
                                @u.UserName
                            </div>
                        </td>
                        <td class="px-6 py-4 text-slate-700">@u.Email</td>
                        <td class="px-6 py-4">
                            @foreach (var r in u.Roles.Split(", "))
                            {
                                <span class="mr-1 inline-flex items-center rounded-full bg-blue-50 px-2.5 py-0.5 text-xs font-medium text-blue-700">@r</span>
                            }
                        </td>
                        <td class="px-6 py-4 text-slate-700">@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td class="px-6 py-4">
                            @if (u.IsLockedOut)
                            {
                                <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-700">Bị khoá</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Hoạt động</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="p-4 border-t border-gray-100">
            <div class="flex justify-end gap-1">
                @for (var i = 1; i <= totalPages; i++)
                {
                    <a class="px-3 py-1 rounded border @(i == page ? "bg-slate-900 text-white" : "bg-white hover:bg-slate-50")"
                       asp-route-page="@i"
                       asp-route-q="@q"
                       asp-route-role="@role"
                       asp-route-pageSize="@pageSize">
                        @i
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const rows = document.querySelectorAll("tr.clickable-row");
            rows.forEach(row => {
                row.style.cursor = "pointer";
                row.addEventListener("mouseover", () => { row.classList.add("bg-gray-50"); });
                row.addEventListener("mouseout", () => { row.classList.remove("bg-gray-50"); });
                row.addEventListener("click", (e) => {
                    // Đảm bảo không click vào một link hay button bên trong (nếu có)
                    if (e.target.tagName === 'A' || e.target.tagName === 'BUTTON') return;

                    const href = row.getAttribute("data-href");
                    if (href) {
                        window.location.href = href;
                    }
                });
            });
        });
    </script>
}