@model MotorShop.Models.Order
@using MotorShop.Models.Enums
@{
    ViewData["Title"] = "Chi tiết đơn hàng #" + Model.Id;
    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    // ----- LOGIC CHO CHUỖI QUY TRÌNH -----
    var processSteps = new[] {
        OrderStatus.Pending,
        OrderStatus.Confirmed,
        OrderStatus.Processing,
        OrderStatus.Delivered,
        OrderStatus.Completed
    };
    int currentStepIndex = Array.IndexOf(processSteps, Model.Status);
    // Nếu đơn đã huỷ, coi như nó ở mốc 0
    if (Model.Status == OrderStatus.Cancelled)
    {
        currentStepIndex = -1;
    }
}

<div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-slate-900">Đơn hàng #@Model.Id</h1>
            <div class="text-sm text-gray-500">
                Đặt lúc @Model.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>
        <a asp-action="Index" class="text-slate-500 hover:text-blue-600 flex items-center gap-1 text-sm font-medium transition-colors">
            <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-2 space-y-6">

            <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-5">
                <h3 class="text-lg font-semibold text-slate-800 mb-6">Quy trình đơn hàng</h3>

                @if (Model.Status == OrderStatus.Cancelled)
                {
                    <div class_="p-4 text-center bg-red-50 text-red-700 rounded-lg">
                        <i class="fa-solid fa-ban fa-xl mr-2"></i>
                        <span class="font-medium">Đơn hàng này đã bị huỷ.</span>
                    </div>
                }
                else
                {
                    <ol class="flex items-center w-full">
                        @foreach (var (step, index) in processSteps.Select((s, i) => (s, i)))
                        {
                            var statusText = step.ToString();
                            string iconClass = "fa-solid fa-spinner animate-spin";
                            string itemClass = "text-blue-600";
                            string lineClass = "bg-gray-200";

                            if (index < currentStepIndex)
                            {
                                // Đã hoàn thành
                                iconClass = "fa-solid fa-check";
                                itemClass = "text-green-600";
                                lineClass = "bg-green-600";
                            }
                            else if (index > currentStepIndex)
                            {
                                // Chưa tới
                                iconClass = "fa-solid fa-clock";
                                itemClass = "text-gray-400";
                            }

                            <li class="relative flex items-center @(index == processSteps.Length - 1 ? "" : "w-full")">
                                @if (index != processSteps.Length - 1)
                                {
                                    <div class="absolute w-full h-0.5 top-5 -right-1/2 @lineClass"></div>
                                }

                                <div class="relative flex flex-col items-center">
                                    <div class="z-10 w-10 h-10 rounded-full flex items-center justify-center @(index <= currentStepIndex ? lineClass : "bg-gray-200")">
                                        <i class="@iconClass @(index <= currentStepIndex ? "text-white" : "text-gray-500")"></i>
                                    </div>
                                    <div class="mt-2 text-center">
                                        <h4 class="text-xs font-semibold @(index <= currentStepIndex ? itemClass : "text-gray-500")">@statusText</h4>
                                    </div>
                                </div>
                            </li>
                        }
                    </ol>
                }
            </div>

            <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl">
                <div class="p-4 border-b">
                    <h3 class_="text-lg font-semibold text-slate-800">Chi tiết sản phẩm</h3>
                </div>
                <div class="divide-y divide-gray-100">
                    @foreach (var item in Model.OrderItems)
                    {
                        <div class="flex items-center gap-4 p-4">
                            @if (item.Product?.PrimaryImageUrl != null)
                            {
                                <img src="@item.Product.PrimaryImageUrl" class="w-16 h-16 rounded-lg object-cover border" />
                            }
                            else
                            {
                                <div class="w-16 h-16 bg-gray-100 rounded-lg flex items-center justify-center text-gray-400">
                                    <i class="fa fa-image fa-lg"></i>
                                </div>
                            }

                            <div class="flex-1">
                                <a asp-area="Admin" asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId"
                                   class="font-medium text-gray-800 hover:text-blue-600 hover:underline">
                                    @(item.Product?.Name ?? "Sản phẩm đã bị xoá")
                                </a>
                                <div class="text-sm text-gray-500">SKU: @(item.Product?.SKU ?? "N/A")</div>
                            </div>
                            <div class="text-sm text-gray-600">
                                @item.UnitPrice.ToString("N0") ₫ x @item.Quantity
                            </div>
                            <div class="text-md font-medium text-gray-900">
                                @(item.UnitPrice* item.Quantity).ToString("N0") ₫
                            </div>
                        </div>
                    }
                </div>
                <div class="p-4 border-t space-y-2 bg-gray-50 rounded-b-xl">
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Tạm tính</span>
                        <span class="font-medium text-gray-800">@Model.OrderItems.Sum(oi => oi.UnitPrice * oi.Quantity).ToString("N0") ₫</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Phí vận chuyển</span>
                        <span class="font-medium text-gray-800">@Model.ShippingFee.ToString("N0") ₫</span>
                    </div>
                    <div class="flex justify-between text-lg font-semibold">
                        <span class="text-gray-900">Tổng cộng</span>
                        <span class="text-blue-600">@Model.TotalAmount.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="lg:col-span-1 space-y-6">

            <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-5">
                <h3 class="text-lg font-semibold text-slate-800 mb-4">Hành động</h3>
                <form asp-action="UpdateStatus" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                    <div class="space-y-3">
                        @if (Model.Status == OrderStatus.Pending)
                        {
                            <button type="submit" name="status" value="@OrderStatus.Confirmed"
                                    class="w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
                                <i class="fa-solid fa-check mr-1"></i> Xác nhận đơn hàng
                            </button>
                        }
                        @if (Model.Status == OrderStatus.Confirmed)
                        {
                            <button type="submit" name="status" value="@OrderStatus.Processing"
                                    class="w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
                                <i class="fa-solid fa-box-open mr-1"></i> Bắt đầu xử lý
                            </button>
                        }
                        @if (Model.Status == OrderStatus.Processing)
                        {
                            <button type="submit" name="status" value="@OrderStatus.Delivered"
                                    class="w-full px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">
                                <i class="fa-solid fa-truck mr-1"></i> Đánh dấu đã giao
                            </button>
                        }
                        @if (Model.Status == OrderStatus.Delivered)
                        {
                            <button type="submit" name="status" value="@OrderStatus.Completed"
                                    class="w-full px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-lg hover:bg-green-700 transition-colors shadow-sm">
                                <i class="fa-solid fa-circle-check mr-1"></i> Hoàn tất đơn
                            </button>
                        }

                        @if (Model.Status != OrderStatus.Completed && Model.Status != OrderStatus.Cancelled && Model.Status != OrderStatus.Delivered)
                        {
                            <button type="submit" name="status" value="@OrderStatus.Cancelled"
                                    class="w-full px-4 py-2 text-sm font-medium text-red-700 bg-red-50 rounded-lg hover:bg-red-100 transition-colors">
                                <i class="fa-solid fa-ban mr-1"></i> Huỷ đơn hàng
                            </button>
                        }
                    </div>
                </form>
            </div>

            <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-5">
                <h3 class_="text-lg font-semibold text-slate-800 mb-4">Thông tin Giao hàng</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-500">Tên:</span>
                        <span class="font-medium text-gray-900 text-right">@Model.ReceiverName</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">SĐT:</span>
                        <span class="font-medium text-gray-900">@Model.ReceiverPhone</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Email:</span>
                        <span class="font-medium text-gray-900 text-right">@Model.ReceiverEmail</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-500">Phương thức:</span>
                        <span class="font-medium text-gray-900">@Model.DeliveryMethod.ToString()</span>
                    </div>
                    <div class="pt-2 border-t mt-2 text-gray-600">@Model.ShippingAddress</div>
                </div>
            </div>

            <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-5">
                <h3 class="text-lg font-semibold text-slate-800 mb-4">Thanh toán</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Phương thức:</span>
                        <span class="font-medium text-gray-900">@Model.PaymentMethod.ToString()</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600">Trạng thái:</span>
                        @if (Model.PaymentStatus == PaymentStatus.Paid)
                        {
                            <span class="font-medium text-green-600">Đã thanh toán</span>
                        }
                        else
                        {
                            <span class="font-medium text-yellow-600">Chờ thanh toán</span>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PaymentRef))
                    {
                        <div class="flex justify-between">
                            <span class="text-gray-600">Mã GD:</span>
                            <span class="font-medium text-gray-900 font-mono text-xs">@Model.PaymentRef</span>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.CustomerNote))
            {
                <div class="bg-white shadow-sm ring-1 ring-black/5 rounded-xl p-5">
                    <h3 class="text-lg font-semibold text-slate-800 mb-2">Ghi chú của khách</h3>
                    <p class="text-sm text-gray-600 italic">"@Model.CustomerNote"</p>
                </div>
            }

        </div>
    </div>
</div>