@model List<MotorShop.Models.Order>
@using MotorShop.Models.Enums
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    var q = (string?)ViewBag.Q ?? string.Empty;
    OrderStatus? status = (OrderStatus?)ViewBag.Status;
    var from = (string?)ViewBag.From ?? string.Empty;
    var to = (string?)ViewBag.To ?? string.Empty;
    var sort = (string?)ViewBag.Sort ?? "date_desc";
    int pageSize = (int)(ViewBag.PageSize ?? 15);
    int page = (int)(ViewBag.Page ?? 1);
    int totalPages = (int)(ViewBag.TotalPages ?? 1);
    
    var statusCounts = (Dictionary<OrderStatus, int>)(ViewBag.StatusCounts ?? new Dictionary<OrderStatus, int>());
    var totalOrders = statusCounts.Values.Sum();
}

<h1 class="text-2xl font-semibold mb-4 text-slate-900">Đơn hàng</h1>

<div class="flex flex-wrap items-center gap-2 mb-4">
    <a asp-action="Index" 
       asp-route-status="" asp-route-q="@q" asp-route-from="@from" asp-route-to="@to" asp-route-sort="@sort" asp-route-pageSize="@pageSize"
       class="px-4 py-2 text-sm font-medium rounded-lg transition-colors
       @(status == null ? "bg-blue-600 text-white shadow-sm" : "bg-white text-gray-700 hover:bg-gray-50 ring-1 ring-gray-200")">
        Tất cả (@totalOrders)
    </a>

    @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
    {
        var count = statusCounts.GetValueOrDefault(s, 0);
        if (count > 0 || status == s)
        {
            <a asp-action="Index" 
               asp-route-status="@s" asp-route-q="@q" asp-route-from="@from" asp-route-to="@to" asp-route-sort="@sort" asp-route-pageSize="@pageSize"
               class="px-4 py-2 text-sm font-medium rounded-lg transition-colors
               @(status == s ? "bg-blue-600 text-white shadow-sm" : "bg-white text-gray-700 hover:bg-gray-50 ring-1 ring-gray-200")">
                @s.ToString() (@count)
            </a>
        }
    }
</div>

<div class="bg-white rounded-xl shadow ring-1 ring-black/5">

    <form method="get" class="p-4 border-b border-gray-100">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-3">
                <input name="q" value="@q" class="border rounded-md px-3 py-2 text-sm w-40" placeholder="Tìm ID, Tên, SĐT..." />
                
                <input name="from" value="@from" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" 
                       class="border rounded-md px-3 py-2 text-sm text-gray-500" placeholder="Từ ngày" />
                       
                <input name="to" value="@to" type="text" onfocus="(this.type='date')" onblur="(this.type='text')" 
                       class="border rounded-md px-3 py-2 text-sm text-gray-500" placeholder="Đến ngày" />
                
                <select name="sort" class="border rounded-md px-3 py-2 text-sm">
                    <option value="date_desc" selected="@(sort == "date_desc")">Sắp xếp: Mới nhất</option>
                    <option value="date_asc" selected="@(sort == "date_asc")">Sắp xếp: Cũ nhất</option>
                    <option value="total_desc" selected="@(sort == "total_desc")">Sắp xếp: Giá trị cao</option>
                    <option value="total_asc" selected="@(sort == "total_asc")">Sắp xếp: Giá trị thấp</option>
                </select>

                <select name="pageSize" class="border rounded-md px-3 py-2 text-sm">
                    <option value="15" selected="@(pageSize == 15)">Hiển thị: 15</option>
                    <option value="25" selected="@(pageSize == 25)">Hiển thị: 25</option>
                    <option value="50" selected="@(pageSize == 50)">Hiển thị: 50</option>
                </select>

                <button class="px-3 py-2 rounded-md bg-slate-100 text-slate-700 text-sm font-medium hover:bg-slate-200">Lọc</button>
            </div>
        </div>
    </form>

    <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
            <thead>
                <tr class="text-left text-xs font-medium text-slate-500 uppercase tracking-wider">
                    <th class="px-6 py-3">Đơn hàng</th>
                    <th class="px-6 py-3">Khách hàng</th>
                    <th class="px-6 py-3">Ngày đặt</th>
                    <th class="px-6 py-3">Tổng tiền</th>
                    <th class="px-6 py-3">Thanh toán</th>
                    <th class="px-6 py-3">Trạng thái</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                @foreach (var item in Model)
                {
                    <tr class="clickable-row" data-href="@Url.Action("Details", "Order", new { id = item.Id })">
                        <td class="px-6 py-4">
                            <div class="font-semibold text-blue-600">#@item.Id</div>
                            <div class="text-xs text-gray-500">@item.DeliveryMethod.ToString()</div>
                        </td>
                        <td class="px-6 py-4">
                            <div class="font-medium text-gray-900">@(item.ReceiverName ?? "N/A")</div>
                            <div class="text-slate-500 text-xs">@(item.ReceiverPhone ?? "N/A")</div>
                        </td>
                        <td class="px-6 py-4 text-slate-700">@item.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="px-6 py-4 font-medium text-slate-900">@item.TotalAmount.ToString("N0") ₫</td>
                        <td class="px-6 py-4">
                            @if (item.PaymentStatus == PaymentStatus.Paid)
                            {
                                <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700">Đã thanh toán</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-700">Chờ thanh toán</span>
                            }
                        </td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700">
                                @item.Status.ToString()
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="p-4 border-t border-gray-100">
            <div class="flex justify-end gap-1">
                @for (var i = 1; i <= totalPages; i++)
                {
                    <a class="px-3 py-1 rounded border @(i == page ? "bg-slate-900 text-white" : "bg-white hover:bg-slate-50")"
                       asp-route-page="@i"
                       asp-route-q="@q"
                       asp-route-status="@status"
                       asp-route-from="@from"
                       asp-route-to="@to"
                       asp-route-sort="@sort"
                       asp-route-pageSize="@pageSize">
                        @i
                    </a>
                }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const rows = document.querySelectorAll("tr.clickable-row");
            rows.forEach(row => {
                row.style.cursor = "pointer";
                row.addEventListener("mouseover", () => { row.classList.add("bg-gray-50"); });
                row.addEventListener("mouseout", () => { row.classList.remove("bg-gray-50"); });
                row.addEventListener("click", () => {
                    const href = row.getAttribute("data-href");
                    if (href) {
                        window.location.href = href;
                    }
                });
            });
        });
    </script>
}